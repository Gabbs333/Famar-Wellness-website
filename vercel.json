{
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    },
    "api/test-diagnostic.js": {
      "maxDuration": 10
    },
    "api/optimize-image.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/test-diagnostic",
      "destination": "/api/test-diagnostic.js"
    },
    {
      "source": "/api/optimize-image",
      "destination": "/api/optimize-image.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "NODE_VERSION": "20"
  }
}